# === Navidrome ===

# Data folder (host path = container path)
ND_DATAFOLDER=/home/sh1ny/navidrome/data

# Music library path on the host
ND_SHAREDFOLDERS=/home/sh1ny/Groovernor

# Music folder path inside the container
ND_MUSICFOLDER=/music

# Library scan frequency — 1h | 30m | @daily | 0 (disabled)
ND_SCANSCHEDULE=1h

# Log level — error | warn | info | debug | trace
ND_LOGLEVEL=info

# Session timeout before automatic logout
ND_SESSIONTIMEOUT=24h